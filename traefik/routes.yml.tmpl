http:
  routers:
    opt:
      entryPoints: [web]
      rule: "PathPrefix(`/api/content`) || PathPrefix(`/api/phones`)"
      service: opt

    sportzavod:
      entryPoints: [web]
      rule: "PathPrefix(`/api/sportzavod`)"
      service: sportzavod
      middlewares: [sportzavod-strip]

    contentzavod:
      entryPoints: [web]
      rule: "PathPrefix(`/api/contentzavod`)"
      service: contentzavod
      middlewares: [contentzavod-strip]

    dashboard:
      entryPoints: [web]
      rule: "PathPrefix(`/api/dashboard`)"
      service: dashboard-api
      middlewares: [dashboard-strip]

  middlewares:
    sportzavod-strip:
      stripPrefix:
        prefixes: ["/api/sportzavod"]
    contentzavod-strip:
      stripPrefix:
        prefixes: ["/api/contentzavod"]
    dashboard-strip:
      stripPrefix:
        prefixes: ["/api/dashboard"]

  services:
    opt:
      loadBalancer:
        servers:
          - url: "${OPT_URL}"

    sportzavod:
      loadBalancer:
        servers:
          - url: "http://sportzavod.railway.internal:${SPORTZAVOD_PORT}"

    contentzavod:
      loadBalancer:
        servers:
          - url: "http://contentzavod.railway.internal:${CONTENTZAVOD_PORT}"

    dashboard-api:
      loadBalancer:
        servers:
          - url: "http://dashboard-api.railway.internal:${DASHBOARD_API_PORT}"
